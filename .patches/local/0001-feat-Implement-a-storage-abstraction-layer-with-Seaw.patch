+async def chat_endpoint(
+    request: Request,
+    chat_request: ChatRequest,
+    db: AsyncSupabaseClient = Depends(get_async_db),
+) -> ChatResponse:
+    try:
+        if not chat_request.chatInput and not chat_request.audioData and not chat_request.imageUrl:
