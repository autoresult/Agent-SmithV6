+                logger.info(f"[CHAT] Creating new conversation for session {chat_request.sessionId}")
+                try:
+                    new_conv = {
+                        "company_id": str(chat_request.companyId),
+                        "user_id": str(chat_request.userId) if chat_request.userId else None,
