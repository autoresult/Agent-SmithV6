+                .execute()
+            )
+
+            available_docs = docs_query.data
+            if len(available_docs) < sample_size:
+                raise ValueError(
+                    f"Agent {agent_id} needs at least {sample_size} completed documents, found {len(available_docs)}."
+                )
+
+            sample_docs = random.sample(available_docs, sample_size)
+
+            # 🔥 PROGRESSO: Documentos carregados
