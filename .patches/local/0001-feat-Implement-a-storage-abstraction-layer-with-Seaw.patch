+
+        return {
+            "period": period_label,
+            "daily": daily_list
+        }
+
+    except Exception as e:
+        logger.error(f"[Billing API] Error getting daily usage: {e}")
+        raise HTTPException(status_code=500, detail=str(e)) from e
