+
+# ===== MODELS =====
+
+
+class ProviderInfo(BaseModel):
+    """Informações sobre um provider"""
+
+    name: str = Field(..., description="Nome do provider (openai, anthropic, google)")
+    display_name: str = Field(..., description="Nome para exibir na UI")
