+
+
+class AgentPublicResponse(BaseModel):
+    """Public-safe response for widget embedding"""
+    id: UUID
+    company_id: UUID  # Required for chat endpoint
+    name: str
+    avatar_url: Optional[str] = None
+    widget_config: Optional[Dict[str, Any]] = None
