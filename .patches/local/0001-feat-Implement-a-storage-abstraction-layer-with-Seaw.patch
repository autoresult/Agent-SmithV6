+                    .execute()
+                )
+            return ChatResponse(output="", companyId=str(chat_request.companyId), sessionId=str(chat_request.sessionId))
+
+        # ==============================================================================
+        # BALANCE CHECK (Paywall)
+        # ==============================================================================
